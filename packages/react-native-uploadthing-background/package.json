{
  "name": "react-native-uploadthing-background",
  "version": "0.0.1",
  "description": "Background UploadThing uploads for Expo apps using Nitro Modules.",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "react-native": "./src/index.ts",
  "source": "./src/index.ts",
  "files": [
    "src",
    "nitrogen",
    "plugin",
    "react-native.config.js",
    "expo-module.config.json",
    "app.plugin.js",
    "nitro.json",
    "android/build.gradle",
    "android/gradle.properties",
    "android/fix-prefab.gradle",
    "android/CMakeLists.txt",
    "android/src",
    "cpp",
    "ios/**/*.h",
    "ios/**/*.m",
    "ios/**/*.mm",
    "ios/**/*.cpp",
    "ios/**/*.swift",
    "*.podspec",
    "README.md"
  ],
  "scripts": {
    "clean": "git clean -xdf android/build lib node_modules",
    "specs": "bunx nitrogen --log-level debug",
    "typecheck": "tsc --noEmit"
