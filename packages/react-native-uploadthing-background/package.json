  "bugs": {
    "url": "https://github.com/AugusDogus/whisp/issues"
  },
  "homepage": "https://github.com/AugusDogus/whisp#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "expo": ">=54.0.0",
    "react": ">=19.0.0",
    "react-native": ">=0.81.0",
    "react-native-nitro-modules": ">=0.35.2"
  },
  "dependencies": {
    "uploadthing": "catalog:"
  },
  "devDependencies": {
    "@acme/tsconfig": "workspace:*",
    "nitrogen": "0.35.2",
    "typescript": "catalog:"
  }
