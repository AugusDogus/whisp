  "keywords": [
    "react-native",
    "expo",
    "uploadthing",
    "background-upload",
    "nitro"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AugusDogus/whisp.git"
  },
  "author": "Whisp",
